# Configuración de Flask
SECRET_KEY=clave_secreta_super_segura_123
DEBUG=True

# Configuración de PostgreSQL
POSTGRES_USER=usuario_postgres_ejemplo
POSTGRES_PASSWORD=contraseña_segura_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nombre_base_de_datos

# Configuración de Instagram Webhook
# Token de verificación que configurarás en Facebook App Dashboard
INSTAGRAM_VERIFY_TOKEN=token_verificacion_webhook
# App Secret de tu aplicación de Facebook/Instagram
INSTAGRAM_APP_SECRET=tu_app_secret_aqui
# Verificar firma del webhook (True en producción)
VERIFY_SIGNATURE=False

# Token de acceso de Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=EAAB1234567890...token_largo_de_acceso_aqui
# ID de tu cuenta de negocio de Instagram
INSTAGRAM_BUSINESS_ACCOUNT_ID=12345678901234567

# Configuración del servidor
PORT=5000
HOST=0.0.0.0
